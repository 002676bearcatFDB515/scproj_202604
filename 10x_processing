# Define sample metadata in one place
sample_info <- data.frame(
  id        = c("63", "68", "71", "73", "79", "80", "83", "84", "87", "88", "90", "92"),
  group     = c("G2", "G3", "G1", "G2", "G2", "G3", "G4", "G1", "G1", "G3", "G4", "G4"),
  celltype  = c("Her2-Dxd", "Her-T785", "Model", "Her2-Dxd", "Her2-Dxd",
                "Her-T785", "Her2-Dxd/T75", "Model", "Model", "Her-T785",
                "Her2-Dxd/T75", "Her2-Dxd/T75"),
  stringsAsFactors = FALSE
)

# Read + annotate each object
seurat_list <- lapply(seq_len(nrow(sample_info)), function(i) {
  s   <- sample_info[i, ]
  tag <- paste0(s$group, "_", s$id)

  obj <- readRDS(file = paste0(s$id, ".rds"))
  obj <- RenameCells(obj, add.cell.id = tag)
  obj$tech     <- s$group
  obj$celltype <- s$celltype
  obj$orig.ident <- tag
  obj
})
names(seurat_list) <- paste0(sample_info$group, "_", sample_info$id)

merged <- merge(
  x            = seurat_list[[1]],
  y            = seurat_list[-1],
  add.cell.ids = NULL,          # already renamed above
  project      = "Her2_Study"
)

# Standard downstream workflow
merged <- NormalizeData(merged)
merged <- FindVariableFeatures(merged, selection.method = "vst", nfeatures = 2000)
merged <- ScaleData(merged)
merged <- RunPCA(merged, npcs = 30)
merged <- RunUMAP(merged, dims = 1:30)
merged <- FindNeighbors(merged, dims = 1:30)
merged <- FindClusters(merged, resolution = 0.5)

saveRDS(merged, file = "merged_all_samples.rds")
